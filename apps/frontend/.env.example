# ============================================
# Frontend Environment Variables (Next.js)
# ============================================
# Copy this file to .env.local for local development
# For production, set these in Vercel Dashboard
# ============================================

# Backend API URL
# Local: http://localhost:8080
# Production: Your Railway backend URL
NEXT_PUBLIC_API_URL=https://chosenwell-production.up.railway.app

# Site URL for SEO (sitemap, robots.txt, OpenGraph)
# Local: http://localhost:3000
# Production: https://chosenwell.co.in
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
