# ============================================
# Backend Environment Variables (Go)
# ============================================
# Copy this file to .env for local development
# For production, set these in Railway Dashboard
# ============================================

# PostgreSQL Database Connection String
# Local (Docker): postgresql://healthuser:healthpass@localhost:5432/healthiswealth?sslmode=disable
# Production (Neon): postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://healthuser:healthpass@localhost:5432/healthiswealth?sslmode=disable

# Server Port (Railway sets this automatically)
# Leave empty for Railway, set for local development
PORT=8080

# Frontend URL for CORS
# Local: http://localhost:3000
# Production: https://chosenwell.co.in
FRONTEND_URL=http://localhost:3000
