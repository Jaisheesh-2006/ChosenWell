# --- OS / Editor ---
.DS_Store
Thumbs.db
Desktop.ini

.vscode/
.idea/
*.iml

# --- Root Environment Files ---
.env
.env.local
.env.production
!.env.example

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Node / Next.js (frontend) ---
apps/frontend/node_modules/
apps/frontend/.next/
apps/frontend/out/
apps/frontend/.turbo/
apps/frontend/.vercel/

# TypeScript build info
apps/frontend/*.tsbuildinfo

# Env files (keep templates like .env.example if you add them)
apps/frontend/.env*
!apps/frontend/.env.example

# --- Go (backend) ---
# Binaries
curated-backend
*.exe
*.dll
*.so
*.dylib

# Go test cache / coverage
*.test
*.out
coverage.*

# --- Docker ---
# (Usually nothing to ignore, but keep local override files out of git)
docker-compose.override.yml

# --- Database ---
apps/database/.env
!apps/database/.env.example

# PostgreSQL data (if running locally without Docker)
apps/database/data/
apps/database/pgdata/

# Database dumps and backups
apps/database/*.dump
apps/database/*.sql.gz
apps/database/backups/

# pgAdmin session data
apps/database/pgadmin/

# --- Misc ---
.tmp/
tmp/
