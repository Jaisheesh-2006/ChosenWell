# ============================================
# ChosenWell - Environment Variables
# ============================================
# This file documents all environment variables needed for deployment
# ============================================

# ============================================
# RENDER - Backend + PostgreSQL
# ============================================
# These variables are set in Render Dashboard

# PostgreSQL (Render managed database)
# Render provides DATABASE_URL automatically when you link a PostgreSQL database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Backend Port (Render sets PORT automatically)
PORT=8081

# Frontend URL for CORS (your Vercel deployment URL)
# Add this to allow requests from your Vercel frontend
FRONTEND_URL=https://your-project.vercel.app

# ============================================
# VERCEL - Frontend (Next.js)
# ============================================
# Add these in Vercel Dashboard > Project Settings > Environment Variables

# Your production site URL
NEXT_PUBLIC_SITE_URL=https://chosenwell.co.in

# Backend API URL (your Render backend URL)
# Replace with your actual Render backend URL after deployment
NEXT_PUBLIC_API_URL=https://your-backend-name.onrender.com

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================
# DEPLOYMENT STEPS
# ============================================
#
# --- RENDER (Backend + PostgreSQL) ---
# 1. Create a new PostgreSQL database on Render
# 2. Create a new Web Service for backend
#    - Root Directory: apps/backend
#    - Build Command: go build -o main ./cmd/server
#    - Start Command: ./main
# 3. Link the PostgreSQL database to the backend service
#    - Render will auto-inject DATABASE_URL
# 4. Add environment variable: PORT=8081 (or let Render set it)
# 5. Note your backend URL (e.g., https://chosenwell-api.onrender.com)
#
# --- VERCEL (Frontend) ---
# 1. Import your GitHub repository
# 2. Set Root Directory: apps/frontend
# 3. Add Environment Variables:
#    - NEXT_PUBLIC_SITE_URL=https://chosenwell.co.in (or your Vercel domain)
#    - NEXT_PUBLIC_API_URL=https://your-backend-name.onrender.com
#    - NEXT_TELEMETRY_DISABLED=1
# 4. Deploy!
#
# --- CORS (Important!) ---
# Make sure your backend allows requests from your Vercel domain
# Update CORS settings in apps/backend if needed
#
# ============================================

