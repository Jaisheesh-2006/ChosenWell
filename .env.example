# ============================================
# ChosenWell - Environment Variables
# ============================================
# This file documents all environment variables needed for deployment
# ============================================

# ============================================
# NEON - PostgreSQL Database (Free Tier)
# ============================================
# Sign up at https://neon.tech (free)
# 
# Steps:
# 1. Create account at neon.tech
# 2. Create a new project (choose region: aws-us-east-1 for best Render performance)
# 3. Copy the connection string from the dashboard
#
# Connection string format:
# postgresql://username:password@ep-xxxx-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL='postgresql://neondb_owner:npg_8OKv1eTxDXnu@ep-floral-smoke-a4sp42mp-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# ============================================
# RENDER - Backend (Go)
# ============================================
# These variables are set in Render Dashboard > Environment

# Backend Port (Render sets PORT automatically, but you can override)
PORT=8081

# Frontend URL for CORS (your Vercel deployment URL)
# Add this to allow requests from your Vercel frontend
FRONTEND_URL=https://your-project.vercel.app

# ============================================
# VERCEL - Frontend (Next.js)
# ============================================
# Add these in Vercel Dashboard > Project Settings > Environment Variables

# Your production site URL
NEXT_PUBLIC_SITE_URL=https://chosenwell.co.in

# Backend API URL (your Render backend URL)
# Replace with your actual Render backend URL after deployment
NEXT_PUBLIC_API_URL=https://your-backend-name.onrender.com

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================
# DEPLOYMENT STEPS
# ============================================
#
# --- STEP 1: NEON (PostgreSQL Database) ---
# 1. Go to https://neon.tech and sign up (free)
# 2. Create a new project
#    - Name: chosenwell-db
#    - Region: aws-us-east-1 (same as Render for lower latency)
# 3. Copy the connection string (includes ?sslmode=require)
# 4. Run migrations:
#    - Connect to Neon using psql or their SQL Editor
#    - Execute the SQL from apps/database/migrations/
#    - Execute the SQL from apps/database/seeds/
#
# --- STEP 2: RENDER (Backend) ---
# 1. Go to https://render.com and create a new Web Service
# 2. Connect your GitHub repository
# 3. Configure:
#    - Name: chosenwell-api
#    - Root Directory: apps/backend
#    - Runtime: Go
#    - Build Command: go build -o main ./cmd/api
#    - Start Command: ./main
# 4. Add Environment Variables:
#    - DATABASE_URL = (paste your Neon connection string)
#    - FRONTEND_URL = https://your-vercel-url.vercel.app
# 5. Deploy and note your backend URL (e.g., https://chosenwell-api.onrender.com)
#
# --- STEP 3: VERCEL (Frontend) ---
# 1. Go to https://vercel.com and import your GitHub repository
# 2. Configure:
#    - Root Directory: apps/frontend
#    - Framework Preset: Next.js (auto-detected)
# 3. Add Environment Variables:
#    - NEXT_PUBLIC_SITE_URL = https://chosenwell.co.in
#    - NEXT_PUBLIC_API_URL = https://chosenwell-api.onrender.com (your Render URL)
#    - NEXT_TELEMETRY_DISABLED = 1
# 4. Deploy!
#
# --- STEP 4: Update CORS ---
# After Vercel deploys, go back to Render and update:
#    - FRONTEND_URL = https://your-actual-vercel-domain.vercel.app
#
# --- STEP 5: Custom Domain (chosenwell.co.in) ---
# 1. In Vercel: Settings > Domains > Add chosenwell.co.in
# 2. Update DNS records at your domain registrar as instructed by Vercel
# 3. Vercel will auto-provision SSL certificate
#
# ============================================

